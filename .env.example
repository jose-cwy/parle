# NeonDB connection (Postgres) — use SSL in production
DATABASE_URL=postgresql://user:password@db-host:5432/heartstrings

# JWT secret for session tokens (required in production)
JWT_SECRET=change_this_to_a_strong_secret

# Salt for hashing guest IPs in usage_tracking (random string)
IP_HASH_SALT=change_this_to_a_random_string

# AES-256 key for journal/chat encryption at rest (32 bytes, base64-encoded)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DATA_ENCRYPTION_KEY=

# Comma-separated allowed browser origins (production)
# ALLOWED_ORIGINS=https://parle.com,https://www.parle.com

# Resend API key
RESEND_API_KEY=your_resend_api_key

# App URL for email links
APP_URL=http://localhost:3000

# OpenAI (required for real chat replies — server-side only)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
